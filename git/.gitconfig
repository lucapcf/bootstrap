[alias]
	s = status -sb
	c = commit -m
	d = diff
	co = checkout
	br = branch
	last = log -1 HEAD
	lo = log --oneline -n 10
	cane = commit --amend --no-edit
	pfwl = push --force-with-lease
	li = stash list
	st = stash push -um
	ap = stash apply
	dp = stash drop
	fa = fetch --all
	pa = pull --all
	fp = !git fetch && git pull
	wt = worktree
	wta = worktree add
	wtl = worktree list
	wtr = worktree remove
	wtm = worktree move
	wtp = worktree prune
	wtab = worktree add -b
